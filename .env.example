# RN Debug MCP environment template
# Copy this file to .env and adjust only what you need.

# Public WDA endpoint if you already run WDA yourself.
WDA_BASE_URL=http://127.0.0.1:8100

# Local WDA project launch settings (used by `npm run ios:wda` and iOS autostart fallback).
WDA_PROJECT_PATH=./WebDriverAgent/WebDriverAgent.xcodeproj
WDA_SCHEME=WebDriverAgentRunner
WDA_DEVICE_ID=
WDA_DESTINATION=
WDA_START_TIMEOUT_MS=60000
WDA_LOG_TAIL_CHARS=6000

# WDA source download settings (used by `rndmcp install wda`).
WDA_REPO_URL=https://github.com/appium/WebDriverAgent.git
WDA_GIT_REF=v11.1.6
