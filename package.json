{
  "name": "rn-debug-mcp",
  "version": "0.1.1",
  "description": "RN Debug MCP server",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "rndmcp": "dist/src/index.js"
  },
  "files": [
    "dist/src",
    "scripts/ios-wda.sh",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "wda:install": "node dist/src/index.js install wda",
    "ios:wda": "sh scripts/ios-wda.sh",
    "pretest": "npm run build",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  }
}
